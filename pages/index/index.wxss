.baby-card {
  background: linear-gradient(135deg, #8AD8AE 0%, #5BC58F 50%, #3FB1C7 100%);
  color: #fff;
  padding: 28rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(63, 177, 199, 0.25);
}

.baby-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.baby-emoji {
  font-size: 56rpx;
  line-height: 1;
}

.baby-info {
  flex: 1;
}

.baby-days-row {
  font-size: 28rpx;
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.baby-days {
  font-size: 56rpx;
  font-weight: bold;
  margin: 0 6rpx;
  vertical-align: middle;
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(30, 110, 75, 0.3);
}

.baby-meta {
  font-size: 24rpx;
  opacity: 0.92;
  margin-top: 6rpx;
}

.baby-edit {
  font-size: 32rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  flex-shrink: 0;
}

.baby-milestone {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.28);
  border-radius: 14rpx;
  font-size: 26rpx;
  text-align: center;
  letter-spacing: 1rpx;
}

.baby-empty {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.baby-empty-title {
  font-size: 30rpx;
  font-weight: 500;
}

.baby-empty-sub {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.list-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.since-pill {
  font-size: 24rpx;
  color: #B8771F;
  background: #FFF3D6;
  border: 1rpx solid #F5C66A;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.summary-card {
  text-align: center;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #666;
}

.date-actions {
  display: flex;
  gap: 12rpx;
}

.date-picker, .today-btn {
  font-size: 26rpx;
  color: #5BC58F;
  background: #C6EDD4;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.today-btn {
  color: #fff;
  background: #5BC58F;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.summary-ratio {
  font-size: 28rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.ratio-num {
  color: #5BC58F;
  font-weight: 600;
}

.stool-info {
  color: #999;
}

.quick-card {
  background: linear-gradient(135deg, #D8F0E2 0%, #C6E8D4 100%);
  border: 2rpx solid #9ED7B5;
}

.quick-title {
  font-size: 26rpx;
  color: #2E8753;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quick-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quick-input {
  flex: 1;
  background: #fff;
  border-radius: 8rpx;
  height: 72rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #333;
}

.quick-btn {
  background: #5BC58F;
  color: #fff;
  border-radius: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  border: none;
  box-shadow: 0 4rpx 10rpx rgba(91, 197, 143, 0.3);
}

.quick-btn[disabled] {
  background: #A0D2B4;
  color: #fff;
}

.quick-btn::after {
  border: none;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5EBE0;
  transition: background .15s;
}

.record-item:active {
  background: #FFF8F0;
}

.record-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  line-height: 1;
  flex-shrink: 0;
}

.empty-sub {
  font-size: 24rpx;
  color: #C9BFB5;
  margin-top: 12rpx;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-time {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-interval {
  font-size: 22rpx;
  color: #B8771F;
  background: #FFF3D6;
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 4rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #8D6E63;
  background: #FFF1E0;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-right-inner {
  text-align: right;
}

.milk-tags {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
  margin-bottom: 6rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.breast-tag {
  background: #C6EDD4;
  color: #2E8753;
}

.formula-tag {
  background: #C7E2FF;
  color: #2D72BF;
}

.record-total {
  font-size: 26rpx;
  color: #999;
  text-align: right;
}

.record-arrow {
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
}
