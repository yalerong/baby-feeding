.summary-card {
  text-align: center;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #666;
}

.date-actions {
  display: flex;
  gap: 12rpx;
}

.date-picker, .today-btn {
  font-size: 26rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.today-btn {
  color: #fff;
  background: #4CAF50;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.summary-ratio {
  font-size: 28rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.ratio-num {
  color: #4CAF50;
  font-weight: 600;
}

.stool-info {
  color: #999;
}

.quick-card {
  background: #F1F8E9;
}

.quick-title {
  font-size: 26rpx;
  color: #2E7D32;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quick-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quick-input {
  flex: 1;
  background: #fff;
  border-radius: 8rpx;
  height: 72rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #333;
}

.quick-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  border: none;
}

.quick-btn[disabled] {
  background: #A5D6A7;
  color: #fff;
}

.quick-btn::after {
  border: none;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background .15s;
}

.record-item:active {
  background: #fafafa;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-time {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #8D6E63;
  background: #FFF3E0;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-right-inner {
  text-align: right;
}

.milk-tags {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
  margin-bottom: 6rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.breast-tag {
  background: #E8F5E9;
  color: #2E7D32;
}

.formula-tag {
  background: #E3F2FD;
  color: #1565C0;
}

.record-total {
  font-size: 26rpx;
  color: #999;
  text-align: right;
}

.record-arrow {
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
}
