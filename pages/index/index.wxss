.summary-card {
  text-align: center;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  color: #666;
}

.date-actions {
  display: flex;
  gap: 12rpx;
}

.date-picker, .today-btn {
  font-size: 26rpx;
  color: #88C9A1;
  background: #D4F1E0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.today-btn {
  color: #fff;
  background: #88C9A1;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.summary-ratio {
  font-size: 28rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.ratio-num {
  color: #88C9A1;
  font-weight: 600;
}

.stool-info {
  color: #999;
}

.quick-card {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFEDE5 100%);
  border: 2rpx solid #FFE5D6;
}

.quick-title {
  font-size: 26rpx;
  color: #C97864;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quick-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quick-input {
  flex: 1;
  background: #fff;
  border-radius: 8rpx;
  height: 72rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #333;
}

.quick-btn {
  background: #FFB5A7;
  color: #fff;
  border-radius: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  border: none;
  box-shadow: 0 4rpx 10rpx rgba(255, 181, 167, 0.3);
}

.quick-btn[disabled] {
  background: #FFD3CB;
  color: #fff;
}

.quick-btn::after {
  border: none;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5EBE0;
  transition: background .15s;
}

.record-item:active {
  background: #FFF8F0;
}

.record-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  line-height: 1;
  flex-shrink: 0;
}

.empty-sub {
  font-size: 24rpx;
  color: #C9BFB5;
  margin-top: 12rpx;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-time {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #8D6E63;
  background: #FFF1E0;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-right-inner {
  text-align: right;
}

.milk-tags {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
  margin-bottom: 6rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.breast-tag {
  background: #D4F1E0;
  color: #4A8A60;
}

.formula-tag {
  background: #D6E9FF;
  color: #3F7DBF;
}

.record-total {
  font-size: 26rpx;
  color: #999;
  text-align: right;
}

.record-arrow {
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
}
