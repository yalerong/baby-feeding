.birth-card {
  background: linear-gradient(135deg, #88C9A1 0%, #A8D8B9 100%);
  color: #fff;
}

.birth-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.birth-label {
  font-size: 30rpx;
  font-weight: 500;
}

.birth-value {
  font-size: 30rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.birth-value.placeholder {
  opacity: 0.8;
}

.birth-month {
  font-size: 26rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

.summary-card {
  text-align: center;
}

.filter-card {
  padding: 20rpx 30rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.filter-value {
  color: #88C9A1;
  font-weight: 500;
  margin-left: 10rpx;
}

.arrow-down {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

.vaccine-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #FFFAF5;
}

.vaccine-item:last-child {
  border-bottom: none;
}

.vaccine-item.completed {
  opacity: 0.75;
}

.vaccine-item.overdue-item .vaccine-name,
.vaccine-item.overdue-item .pending-text {
  color: #ff4d4f;
}

.vaccine-main {
  flex: 1;
}

.vaccine-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.vaccine-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.dose-tag {
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.category-tag {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.cat1 {
  background: #D4F1E0;
  color: #4A8A60;
}

.cat2 {
  background: #D6E9FF;
  color: #3F7DBF;
}

.cat-custom {
  background: #FFF1E0;
  color: #E65100;
}

.vaccine-date {
  font-size: 28rpx;
  margin-top: 6rpx;
}

.completed-text {
  color: #88C9A1;
}

.pending-text {
  color: #666;
}

.vaccine-note {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.vaccine-action {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.overdue-badge {
  font-size: 22rpx;
  color: #fff;
  background: #ff4d4f;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.more-btn {
  font-size: 36rpx;
  color: #999;
  padding: 0 16rpx;
  letter-spacing: 1rpx;
  line-height: 1;
}

.overdue-sub {
  color: #ff4d4f;
  margin-left: 4rpx;
  font-size: 22rpx;
}

.vaccine-item:active {
  background: #fafafa;
}
