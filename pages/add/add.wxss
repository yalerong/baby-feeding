.form-card {
  padding: 10rpx 30rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
  width: 160rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #5BC58F;
  text-align: right;
  min-width: 200rpx;
}

.picker-value.placeholder {
  color: #bbb;
}

input {
  font-size: 30rpx;
  color: #333;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.preview-card {
  background: #C6EDD4;
}

.preview-title {
  font-size: 28rpx;
  color: #2E8753;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.preview-content {
  font-size: 30rpx;
  color: #333;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  margin-top: 20rpx;
}

.btn-danger::after {
  border: none;
}
