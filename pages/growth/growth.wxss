.latest-card {
  background: linear-gradient(135deg, #5BC58F 0%, #8AD8AE 100%);
  color: #fff;
}

.latest-row {
  display: flex;
  justify-content: space-around;
}

.latest-item {
  text-align: center;
  flex: 1;
}

.latest-value {
  font-size: 48rpx;
  font-weight: bold;
}

.unit {
  font-size: 24rpx;
  font-weight: normal;
  opacity: 0.9;
}

.latest-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.latest-change {
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.95;
}

.latest-change.up {
  color: #C8E6C9;
}

.latest-change.down {
  color: #FFCDD2;
}

.chart-toggle {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
  box-shadow: 0 6rpx 20rpx rgba(91, 197, 143, 0.10);
}

.toggle-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 18rpx;
  transition: all .15s;
}

.toggle-item.active {
  color: #fff;
  font-weight: 600;
  background: #5BC58F;
}

.chart-card {
  position: relative;
  padding: 20rpx;
}

.chart-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #B0A89F;
  font-size: 28rpx;
  text-align: center;
}

.record-date {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-note {
  font-size: 24rpx;
  color: #999;
}

.tag-wrap {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
}

.weight-tag {
  background: #C6EDD4;
  color: #2E8753;
}

.height-tag {
  background: #C7E2FF;
  color: #2D72BF;
}
