page {
  background-color: #FFFAF5;
  color: #4A4A4A;
}

.container {
  padding: 20rpx 30rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(91, 197, 143, 0.10);
}

.btn-primary {
  background: #5BC58F;
  color: #fff;
  border-radius: 20rpx;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(91, 197, 143, 0.28);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #5BC58F;
  border-radius: 20rpx;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  text-align: center;
  border: 2rpx solid #C6EDD4;
  margin-top: 20rpx;
}

.btn-secondary::after {
  border: none;
}

.empty-tip {
  text-align: center;
  color: #B0A89F;
  padding: 60rpx 0;
  font-size: 28rpx;
  line-height: 1.6;
}

.empty-emoji {
  display: block;
  font-size: 88rpx;
  margin-bottom: 16rpx;
  line-height: 1;
}

.empty-sub {
  font-size: 24rpx;
  color: #C9BFB5;
  margin-top: 12rpx;
}
