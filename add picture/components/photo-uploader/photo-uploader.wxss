.photo-card {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.counter {
  font-size: 26rpx;
  color: #999;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.thumb {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}

.delete-btn {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
}

.upload-btn {
  border: 2rpx dashed #c8c8c8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #888;
  background: #fafafa;
}

.plus {
  font-size: 52rpx;
  line-height: 52rpx;
}

.hint {
  margin-top: 8rpx;
  font-size: 24rpx;
}
